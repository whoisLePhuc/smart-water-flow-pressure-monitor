# Auto-detect text files and normalize repository content to LF
* text=auto eol=lf

# Source code
*.c       text eol=lf
*.h       text eol=lf
*.cpp     text eol=lf
*.hpp     text eol=lf
*.s       text eol=lf
*.S       text eol=lf
*.ld      text eol=lf

# Build system
CMakeLists.txt text eol=lf
*.cmake    text eol=lf
*.mk       text eol=lf
Makefile   text eol=lf

# Configuration and documentation
*.json     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.md       text eol=lf
*.txt      text eol=lf
*.ioc      text eol=lf

# Windows-specific scripts
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# Binary files
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.pdf      binary
*.bin      binary
*.elf      binary
*.hex      binary
*.a        binary
*.lib      binary
*.db       binary